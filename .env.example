# ══════════════════════════════════════════════════════
#  AI 期货交易系统 — 环境配置文件
#  复制此文件为 .env，填入真实值后启动后端
# ══════════════════════════════════════════════════════

# ── 天勤账号（快期/天勤注册的账号）──────────────────────────
TQ_USERNAME=
TQ_PASSWORD=

# ── 交易模式 ─────────────────────────────────────────────────
# TQ_ENABLE_TRADING: true = 允许 AI 自动下单；false = 只看行情和分析
TQ_ENABLE_TRADING=false

# TQ_ACCOUNT_MODE: sim = 快期模拟账户；live = 实盘账户
TQ_ACCOUNT_MODE=sim

# ── 实盘账户（TQ_ACCOUNT_MODE=live 时必填）──────────────────
# TQ_BROKER: 期货公司名称（含前缀），完整列表见 https://www.shinnytech.com/articles/reference/tqsdk-brokers
# 示例：H宏源期货 / Q国泰君安期货 / Z中信期货 / H华泰期货
TQ_BROKER=
TQ_ACCOUNT_ID=
TQ_TRADE_PASSWORD=

# ── AI 模型 API Key（至少填一个）────────────────────────────

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-opus-4-5

# OpenAI GPT
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# Grok (xAI)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL_NAME=grok-3

# 通义千问3 (Qwen3 / 阿里云)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN3_MODEL_NAME=qwen3.5-plus

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL_NAME=gemini-2.5-flash

# OpenRouter（统一接入多家模型，https://openrouter.ai/）
# OPENROUTER_MODEL_NAME 填 OpenRouter 模型格式：provider/model-name
# 示例：google/gemini-2.5-pro / anthropic/claude-opus-4-5 / openai/gpt-4o / deepseek/deepseek-r1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=google/gemini-2.5-pro

# NVIDIA NIM（https://build.nvidia.com/）
# NVIDIA_MODEL_NAME 填 NIM 模型格式：provider/model-name
# 示例：deepseek-ai/deepseek-v3.2 / meta/llama-3.3-70b-instruct / mistralai/mistral-7b-instruct-v0.3
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=deepseek-ai/deepseek-v3.2

# Claude2API
# CLAUDE_API_KEY 填 config.yaml 里的 api_key
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_MODEL_NAME=


# ── 策略选择 ─────────────────────────────────────────────────
# 当前使用的策略 ID（需在 strategies/__init__.py 中注册）
# 可用策略：price_action（默认）
STRATEGY_ID=price_action

# ── 运行参数 ─────────────────────────────────────────────────
# 默认启动合约（主连格式）
DEFAULT_SYMBOL=KQ.m@SHFE.rb

# 默认 AI 模型（claude / openai / deepseek / grok / qwen / gemini）
DEFAULT_MODEL=deepseek

# 每次 AI 下单手数
DEFAULT_TRADE_VOLUME=1

# 分析触发间隔（分钟）：每隔 N 分钟触发一次 AI 分析
ANALYSIS_INTERVAL_MINUTES=5

# 传给 AI 的 K 线根数（默认 40）
# 切换到更长周期（如 15 分钟）时可适当减少，降低 token 消耗
AI_KLINE_COUNT=40

# AI 分析并发数限制（1-10，默认 3）
MAX_CONCURRENT=3

# 预计算趋势斜率窗口（默认 10 根；用于趋势方向判定）
TREND_LOOKBACK_BARS=10

# 后端监听端口
PORT=8888

# ── 企业微信群机器人推送（可选）────────────────────────────────
# 在企业微信群 → 群机器人 → 添加机器人，复制 Webhook URL 中的 key
# 留空则不推送
WECHAT_WEBHOOK_KEY=
